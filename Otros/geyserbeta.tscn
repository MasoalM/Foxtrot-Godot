[sub_resource type="GDScript" id="GDScript_g0r31"]
script/source = "extends Node2D

@export var altura_max = 150
@export var velocidad = 2.0

var tiempo = 0.0
@onready var area = $Area2D

func _process(delta):
	tiempo += delta
	
	var factor = (sin(tiempo * velocidad) + 1) / 2  # de 0 a 1
	var nueva_altura = factor * altura_max

	# Escalar en Y
	area.scale.y = 5*nueva_altura / altura_max
"

